---
// AuthButtons.astro — login/register sin Vue, vanilla JS puro
// Sin v-model, sin reactividad: lee el DOM directamente al hacer submit
---

<!-- Botones de sesión (se actualizan via JS) -->
<div id="auth-root">
  <div id="auth-guest" class="ab-buttons">
    <button id="btn-open-login" class="ab-btn ab-btn--primary" type="button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
      Iniciar sesión
    </button>
    <button id="btn-open-register" class="ab-btn ab-btn--outline" type="button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
      Registrarse
    </button>
  </div>
  <div id="auth-user" class="ab-user" style="display:none">
    <!-- Dropdown trigger -->
    <div class="ab-dropdown-wrap">
      <button id="btn-user-dropdown" class="ab-btn ab-btn--outline ab-dropdown-trigger" type="button" aria-haspopup="true" aria-expanded="false">
        <span id="auth-plan-badge" class="ab-plan-badge" style="display:none"></span>
        <span id="auth-user-email" class="ab-user-email"></span>
        <svg class="ab-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </button>

      <!-- Dropdown menu -->
      <div id="auth-dropdown" class="ab-dropdown" role="menu" aria-hidden="true" inert>
        <!-- Plan info row -->
        <div class="ab-dropdown-plan">
          <span id="dd-plan-badge" class="ab-plan-badge ab-plan-badge--lg"></span>
          <span id="dd-scan-count" class="ab-dropdown-scans">— escaneos este mes</span>
        </div>

        <div class="ab-dropdown-divider"></div>

        <!-- Gestionar suscripción -->
        <button id="btn-portal" class="ab-dropdown-item" type="button" role="menuitem">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          <span id="btn-portal-label">Gestionar suscripción</span>
          <span id="btn-portal-spinner" class="ab-spinner ab-spinner--sm" style="display:none"></span>
        </button>

        <!-- Subir a Pro (solo plan básico) -->
        <button id="btn-upgrade" class="ab-dropdown-item ab-dropdown-item--upgrade" type="button" role="menuitem" style="display:none">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span id="btn-upgrade-label">Subir a Pro — 9,99€/mes</span>
          <span id="btn-upgrade-spinner" class="ab-spinner ab-spinner--sm" style="display:none"></span>
        </button>

        <div class="ab-dropdown-divider"></div>

        <!-- Logout -->
        <button id="btn-logout" class="ab-dropdown-item ab-dropdown-item--danger" type="button" role="menuitem">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Cerrar sesión
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal (JS lo mueve al body) -->
<div id="auth-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="auth-modal-title"
  style="display:none"
  class="ab-overlay">
  <div class="ab-container">
    <div class="ab-header">
      <h2 id="auth-modal-title" class="ab-title">Iniciar sesión</h2>
      <button id="btn-modal-close" class="ab-close" type="button" aria-label="Cerrar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <form id="auth-form" class="ab-body" novalidate autocomplete="on">
      <!-- Honeypot anti-bot -->
      <div class="ab-hp" aria-hidden="true">
        <input type="text" name="website" id="hp-input" tabindex="-1" autocomplete="off" />
      </div>

      <!-- Feedback (error / éxito) -->
      <div id="auth-feedback" role="alert" aria-live="assertive" style="display:none" class="ab-feedback"></div>

      <!-- Nombre (solo registro) -->
      <div id="field-name" class="ab-field" style="display:none">
        <label for="inp-name">Nombre completo</label>
        <input id="inp-name" type="text" placeholder="Tu nombre" autocomplete="name" inputmode="text" />
      </div>

      <!-- Email -->
      <div class="ab-field">
        <label for="inp-email">Email</label>
        <input id="inp-email" type="email" placeholder="tu@email.com" autocomplete="email" inputmode="email" />
      </div>

      <!-- Contraseña -->
      <div class="ab-field">
        <label for="inp-password">Contraseña</label>
        <div class="ab-pass-wrap">
          <input id="inp-password" type="password" placeholder="Mínimo 8 caracteres" autocomplete="current-password" />
          <button type="button" id="btn-toggle-pass" class="ab-pass-toggle" aria-label="Mostrar contraseña">
            <svg id="eye-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg id="eye-off-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
      </div>

      <!-- Submit -->
      <button type="submit" id="auth-submit" class="ab-submit">
        <span id="submit-spinner" class="ab-spinner" style="display:none"></span>
        <span id="submit-label">Iniciar sesión</span>
      </button>

      <!-- Cambiar modo -->
      <p class="ab-toggle">
        <span id="toggle-msg">¿No tienes cuenta?</span>
        <button type="button" id="btn-toggle-mode" class="ab-toggle-btn">Regístrate</button>
      </p>
    </form>
  </div>
</div>

<script>
  import { supabase } from '../../lib/supabaseClient'
  import { currentUser, userProfile, refreshProfile, SCAN_LIMITS } from '../../stores/authStore'
  import { isDisposableEmail, isValidEmailFormat } from '../../lib/disposableEmailDomains'

  // ── Elementos del DOM ─────────────────────────────
  const modal       = document.getElementById('auth-modal')!
  const authGuest   = document.getElementById('auth-guest')!
  const authUser    = document.getElementById('auth-user')!
  const userEmailEl = document.getElementById('auth-user-email')!
  const form        = document.getElementById('auth-form') as HTMLFormElement
  const feedback    = document.getElementById('auth-feedback')!
  const fieldName   = document.getElementById('field-name')!
  const inpEmail    = document.getElementById('inp-email') as HTMLInputElement
  const inpPassword = document.getElementById('inp-password') as HTMLInputElement
  const inpName     = document.getElementById('inp-name') as HTMLInputElement
  const hpInput     = document.getElementById('hp-input') as HTMLInputElement
  const submitBtn   = document.getElementById('auth-submit') as HTMLButtonElement
  const submitSpinner = document.getElementById('submit-spinner')!
  const submitLabel = document.getElementById('submit-label')!
  const modalTitle  = document.getElementById('auth-modal-title')!
  const toggleMsg   = document.getElementById('toggle-msg')!
  const toggleBtn   = document.getElementById('btn-toggle-mode')!
  const eyeIcon     = document.getElementById('eye-icon')!
  const eyeOffIcon  = document.getElementById('eye-off-icon')!

  // ── Elementos del dropdown ─────────────────────────
  const dropdownTrigger = document.getElementById('btn-user-dropdown') as HTMLButtonElement
  const dropdown        = document.getElementById('auth-dropdown')!
  const authPlanBadge   = document.getElementById('auth-plan-badge')!
  const ddPlanBadge     = document.getElementById('dd-plan-badge')!
  const ddScanCount     = document.getElementById('dd-scan-count')!
  const btnUpgrade      = document.getElementById('btn-upgrade') as HTMLButtonElement
  const btnUpgradeLabel = document.getElementById('btn-upgrade-label')!
  const btnUpgradeSpinner = document.getElementById('btn-upgrade-spinner')!
  const btnPortal       = document.getElementById('btn-portal') as HTMLButtonElement
  const btnPortalLabel  = document.getElementById('btn-portal-label')!
  const btnPortalSpinner = document.getElementById('btn-portal-spinner')!

  // Mover modal al body para evitar problemas de z-index/overflow
  document.body.appendChild(modal)

  let mode = 'login'      // 'login' | 'register'
  let openedAt = 0
  let dropdownOpen = false

  // ── Funciones de UI ───────────────────────────────

  function setMode(m: string) {
    mode = m
    const isLogin = m === 'login'
    modalTitle.textContent  = isLogin ? 'Iniciar sesión' : 'Crear cuenta'
    submitLabel.textContent = isLogin ? 'Iniciar sesión' : 'Crear cuenta'
    toggleMsg.textContent   = isLogin ? '¿No tienes cuenta?' : '¿Ya tienes cuenta?'
    toggleBtn.textContent   = isLogin ? 'Regístrate' : 'Inicia sesión'
    fieldName.style.display = isLogin ? 'none' : 'flex'
    if (!isLogin) inpPassword.setAttribute('autocomplete', 'new-password')
    else inpPassword.setAttribute('autocomplete', 'current-password')
  }

  function openModal(m = 'login') {
    setMode(m)
    openedAt = Date.now()
    hideFeedback()
    form.reset()
    modal.style.display = 'flex'
    document.body.style.overflow = 'hidden'
    // Focus al primer campo tras animación
    setTimeout(() => inpEmail.focus(), 100)
  }

  function closeModal() {
    modal.style.display = 'none'
    document.body.style.overflow = ''
    hideFeedback()
    form.reset()
  }

  function showError(msg: string) {
    feedback.textContent = msg
    feedback.className = 'ab-feedback ab-feedback--error'
    feedback.style.display = 'block'
  }

  function showSuccess(msg: string) {
    feedback.textContent = msg
    feedback.className = 'ab-feedback ab-feedback--success'
    feedback.style.display = 'block'
  }

  function hideFeedback() {
    feedback.style.display = 'none'
    feedback.textContent = ''
  }

  function setLoading(on: boolean) {
    submitBtn.disabled = on
    submitSpinner.style.display = on ? 'inline-block' : 'none'
    submitLabel.style.display   = on ? 'none'         : 'inline'
  }

  function translateError(msg: string) {
    const m = (msg || '').toLowerCase()
    if (m.includes('invalid login credentials') || m.includes('invalid email or password'))
      return 'Email o contraseña incorrectos.'
    if (m.includes('email not confirmed'))
      return 'Confirma tu email antes de entrar. Revisa tu bandeja de entrada.'
    if (m.includes('user already registered') || m.includes('already been registered'))
      return 'Ya existe una cuenta con ese email. Inicia sesión.'
    if (m.includes('password should be at least'))
      return 'La contraseña debe tener al menos 8 caracteres.'
    if (m.includes('rate limit') || m.includes('too many requests'))
      return 'Demasiados intentos. Espera unos minutos.'
    if (m.includes('network') || m.includes('fetch') || m.includes('failed'))
      return 'Error de conexión. Comprueba tu internet.'
    return msg || 'Error desconocido. Inténtalo de nuevo.'
  }

  // ── Dropdown helpers ──────────────────────────────

  function openDropdown() {
    dropdownOpen = true
    dropdown.classList.add('ab-dropdown--open')
    dropdown.removeAttribute('inert')
    dropdown.setAttribute('aria-hidden', 'false')
    dropdownTrigger.setAttribute('aria-expanded', 'true')
    dropdownTrigger.classList.add('ab-dropdown-trigger--active')
    // Ensure dropdown doesn't overflow viewport on mobile
    const rect = dropdownTrigger.getBoundingClientRect()
    const spaceRight = window.innerWidth - rect.right
    if (spaceRight < 220) {
      dropdown.classList.add('ab-dropdown--right')
    } else {
      dropdown.classList.remove('ab-dropdown--right')
    }
  }

  function closeDropdown() {
    dropdownOpen = false
    dropdown.classList.remove('ab-dropdown--open')
    dropdown.setAttribute('inert', '')
    dropdown.setAttribute('aria-hidden', 'true')
    dropdownTrigger.setAttribute('aria-expanded', 'false')
    dropdownTrigger.classList.remove('ab-dropdown-trigger--active')
  }

  function toggleDropdown() {
    if (dropdownOpen) closeDropdown()
    else openDropdown()
  }

  // ── Plan badge text & scan counts ─────────────────

  function getPlanLabel(tier: string | null): string {
    if (tier === 'pro') return 'PLAN PRO'
    if (tier === 'basico') return 'PLAN BÁSICO'
    return ''
  }

  function getPlanClass(tier: string | null): string {
    if (tier === 'pro') return 'ab-plan-badge--pro'
    if (tier === 'basico') return 'ab-plan-badge--basico'
    return ''
  }

  function updateDropdownProfile(profile: any) {
    const tier = profile?.subscription_tier ?? null
    const planLabel = getPlanLabel(tier)
    const planClass = getPlanClass(tier)

    // Trigger badge
    if (planLabel) {
      authPlanBadge.textContent = planLabel
      authPlanBadge.className = 'ab-plan-badge ' + planClass
      authPlanBadge.style.display = 'inline-flex'
    } else {
      authPlanBadge.style.display = 'none'
    }

    // Dropdown plan badge
    ddPlanBadge.textContent = planLabel || '—'
    ddPlanBadge.className = 'ab-plan-badge ab-plan-badge--lg ' + planClass

    // Scan count text
    if (profile && tier) {
      const limit = (SCAN_LIMITS as any)[tier] ?? 0
      const used = profile.monthly_scans_used ?? 0
      ddScanCount.textContent = `${used} / ${limit} escaneos este mes`
    } else if (profile) {
      ddScanCount.textContent = '— escaneos este mes'
    } else {
      ddScanCount.textContent = '— escaneos este mes'
    }

    // Show "Subir a Pro" only for basico plan
    btnUpgrade.style.display = (tier === 'basico') ? 'flex' : 'none'
  }

  // ── Actualizar UI según sesión ────────────────────

  function updateAuthUI(user: any) {
    if (user) {
      authGuest.style.display = 'none'
      authUser.style.display  = 'flex'
      // Truncate email in trigger
      const email = user.email || ''
      userEmailEl.textContent = email
    } else {
      authGuest.style.display = 'flex'
      authUser.style.display  = 'none'
      closeDropdown()
    }
  }

  // Suscribirse al nanostore para mantener UI en sync con Vue islands
  currentUser.subscribe(updateAuthUI)

  // Suscribirse al perfil para actualizar dropdown reactivamente
  userProfile.subscribe((profile) => {
    updateDropdownProfile(profile)
  })

  // Cargar sesión inicial
  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session?.user) {
      currentUser.set(session.user)
      refreshProfile()
    }
  })

  // ── Event listeners ───────────────────────────────

  document.getElementById('btn-open-login')!.addEventListener('click', () => openModal('login'))
  document.getElementById('btn-open-register')!.addEventListener('click', () => openModal('register'))
  document.getElementById('btn-modal-close')!.addEventListener('click', closeModal)

  // Cerrar al hacer click fuera del contenedor
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal()
  })

  // Cerrar dropdown al hacer click fuera
  document.addEventListener('click', (e) => {
    const wrap = document.querySelector('.ab-dropdown-wrap')
    if (dropdownOpen && wrap && !wrap.contains(e.target as Node)) {
      closeDropdown()
    }
  })

  // Escape para cerrar modal y dropdown
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (modal.style.display !== 'none') closeModal()
      if (dropdownOpen) closeDropdown()
    }
  })

  // Toggle dropdown
  dropdownTrigger.addEventListener('click', (e) => {
    e.stopPropagation()
    toggleDropdown()
  })

  // Toggle mostrar/ocultar contraseña
  document.getElementById('btn-toggle-pass')!.addEventListener('click', () => {
    const isPass = inpPassword.type === 'password'
    inpPassword.type = isPass ? 'text' : 'password'
    eyeIcon.style.display    = isPass ? 'none'  : 'block'
    eyeOffIcon.style.display = isPass ? 'block' : 'none'
    document.getElementById('btn-toggle-pass')!.setAttribute(
      'aria-label', isPass ? 'Ocultar contraseña' : 'Mostrar contraseña'
    )
  })

  // Cambiar modo login ↔ register
  toggleBtn.addEventListener('click', () => {
    setMode(mode === 'login' ? 'register' : 'login')
    hideFeedback()
  })

  // Logout
  document.getElementById('btn-logout')!.addEventListener('click', async () => {
    closeDropdown()
    // scope: 'local' limpia solo el estado local sin petición al servidor,
    // evita 403 cuando el token ya está expirado
    try { await supabase.auth.signOut({ scope: 'local' }) } catch {}
    currentUser.set(null)
    userProfile.set(null)
  })

  // Gestionar suscripción → customer portal
  btnPortal.addEventListener('click', async () => {
    btnPortal.disabled = true
    btnPortalLabel.style.display = 'none'
    btnPortalSpinner.style.display = 'inline-block'
    try {
      const { data: { session } } = await supabase.auth.getSession()
      if (!session) return
      const res = await fetch('/api/customer-portal', {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${session.access_token}` },
      })
      if (res.ok) {
        const { url } = await res.json()
        if (url) window.location.href = url
      }
    } catch (err) {
      console.error('customer-portal error:', err)
    } finally {
      btnPortal.disabled = false
      btnPortalLabel.style.display = 'inline'
      btnPortalSpinner.style.display = 'none'
    }
  })

  // Subir a Pro → upgrade plan
  btnUpgrade.addEventListener('click', async () => {
    btnUpgrade.disabled = true
    btnUpgradeLabel.style.display = 'none'
    btnUpgradeSpinner.style.display = 'inline-block'
    try {
      const { data: { session } } = await supabase.auth.getSession()
      if (!session) return
      const res = await fetch('/api/upgrade-plan', {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${session.access_token}` },
      })
      if (res.ok) {
        const json = await res.json()
        // If API returns a checkout/redirect URL, follow it
        if (json?.url) {
          window.location.href = json.url
          return
        }
        // Otherwise refresh profile to reflect new tier
        await refreshProfile()
      }
    } catch (err) {
      console.error('upgrade-plan error:', err)
    } finally {
      btnUpgrade.disabled = false
      btnUpgradeLabel.style.display = 'inline'
      btnUpgradeSpinner.style.display = 'none'
    }
  })

  // Escuchar evento desde InvoiceScanner u otros componentes Vue
  document.addEventListener('open-auth-modal', (e: any) => {
    openModal(e.detail?.mode || 'login')
  })

  // ── Submit del formulario ─────────────────────────

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    hideFeedback()

    // Anti-bot honeypot
    if (hpInput.value) return

    // Leer valores del DOM directamente (resuelve autofill en móvil)
    const email    = inpEmail.value.trim()
    const password = inpPassword.value
    const fullName = inpName.value.trim()

    // Validación con feedback al usuario
    if (!email) {
      showError('Introduce tu email.')
      inpEmail.focus()
      return
    }
    if (!isValidEmailFormat(email)) {
      showError('El email no tiene un formato válido.')
      inpEmail.focus()
      return
    }
    if (!password) {
      showError('Introduce tu contraseña.')
      inpPassword.focus()
      return
    }
    if (password.length < 8) {
      showError('La contraseña debe tener al menos 8 caracteres.')
      inpPassword.focus()
      return
    }
    if (mode === 'register') {
      if (!fullName) {
        showError('Introduce tu nombre completo.')
        inpName.focus()
        return
      }
      if (Date.now() - openedAt < 1500) {
        showError('Por favor, inténtalo de nuevo.')
        return
      }
      if (isDisposableEmail(email)) {
        showError('No se permiten emails temporales. Usa tu email real.')
        return
      }
    }

    setLoading(true)
    try {
      if (mode === 'login') {
        const { data, error } = await supabase.auth.signInWithPassword({ email, password })
        if (error) {
          showError(translateError(error.message))
        } else if (data?.user) {
          currentUser.set(data.user)
          await refreshProfile()
          closeModal()
        }
      } else {
        const { data, error } = await supabase.auth.signUp({
          email,
          password,
          options: { data: { full_name: fullName } }
        })
        if (error) {
          showError(translateError(error.message))
        } else if (data?.user && !data?.session) {
          showSuccess('Revisa tu email para confirmar tu cuenta.')
        } else if (data?.user) {
          currentUser.set(data.user)
          await refreshProfile()
          closeModal()
        }
      }
    } catch {
      showError('Error de conexión. Comprueba tu internet e inténtalo de nuevo.')
    } finally {
      setLoading(false)
    }
  })
</script>

<style>
/* ── Auth buttons ─────────────────────────────── */
.ab-buttons, .ab-user {
  display: flex;
  gap: 0.5rem;
  align-items: center;
  flex-wrap: wrap;
}

.ab-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 1rem;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  border: none;
  font-family: inherit;
  white-space: nowrap;
}

.ab-btn--primary { background: var(--primary-500); color: var(--neutral-50); }
.ab-btn--primary:hover { background: var(--primary-400); }
.ab-btn--outline { background: transparent; color: var(--primary-100); border: 1px solid var(--primary-600); }
.ab-btn--outline:hover { background: var(--primary-800); border-color: var(--primary-500); }

.ab-user-email {
  font-size: 0.85rem;
  color: var(--primary-200);
  max-width: 130px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── Plan badge ───────────────────────────────── */
.ab-plan-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  white-space: nowrap;
  flex-shrink: 0;
}

.ab-plan-badge--pro {
  background: linear-gradient(135deg, var(--amber), var(--orange));
  color: var(--primary-900);
}

.ab-plan-badge--basico {
  background: var(--primary-700);
  color: var(--primary-200);
  border: 1px solid var(--primary-600);
}

.ab-plan-badge--lg {
  font-size: 0.75rem;
  padding: 0.2rem 0.55rem;
}

/* ── Dropdown wrap ────────────────────────────── */
