---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Calculator from "../components/Calculator.vue";
import Faq from "../components/Faq.astro";
import SubscribeForm from "../components/SubscribeForm.vue";
import ListNewsletter from "../components/ListNewsletter.astro";
import heroImg from "../assets/imgs/calculator.webp";
import { faqData } from "../constant";
import ApplianceGrid from "../components/ApplianceGrid.astro";
const conical = "https://calculatuluz.es";


export const columns = [
  {
    accessorKey: "name",
    header: "Electrodoméstico",
  },
  {
    accessorKey: "power",
    header: "Potencia típica (W)",
  },
  {
    accessorKey: "kwh",
    header: "Consumo aprox. (kWh/h)",
  },
];

export const data = [
  { name: "Nevera", power: "150 – 300 W", kwh: "0,15 – 0,30 kWh/h" },
  { name: "Lavadora (ciclo completo)", power: "1500 – 2000 W", kwh: "1,5 – 2,0 kWh/h" },
  { name: "Lavavajillas", power: "1200 – 2000 W", kwh: "1,2 – 2,0 kWh/h" },
  { name: "Horno eléctrico", power: "1200 – 2500 W", kwh: "1,2 – 2,5 kWh/h" },
  { name: "Microondas", power: "800 – 1200 W", kwh: "0,8 – 1,2 kWh/h" },
  { name: "Vitrocerámica", power: "900 – 2000 W", kwh: "0,9 – 2,0 kWh/h" },
  { name: "Televisor LED", power: "80 – 200 W", kwh: "0,08 – 0,20 kWh/h" },
  { name: "Ordenador portátil", power: "50 – 100 W", kwh: "0,05 – 0,1 kWh/h" },
  { name: "Aire acondicionado", power: "1000 – 3000 W", kwh: "1,0 – 3,0 kWh/h" },
  { name: "Secador de pelo", power: "1000 – 2200 W", kwh: "1,0 – 2,2 kWh/h" },
];

import Table from "@/components/Table";
---

<Layout
  title="⚡ Calculadora consumo eléctrico de electrodomésticos en kWh y euros | Gratis online"
  description="Calcula gratis y online el consumo eléctrico de tus electrodomésticos en kWh y euros. Consulta el precio de la luz por horas en tiempo real y ahorra en tu factura de electricidad."
  conical={conical}
>
  <div class="text-primary-100 mt-space-l">
    <div class="hero-wrapper">
      <div>
        <h1 class="fw-700 text-neutral-50">
          Calculadora de consumo eléctrico de electrodomésticos en kWh y euros
        </h1>
        <p class="mt-space-m">
          Con esta calculadora online de consumo eléctrico de electrodomésticos
          podrás saber en segundos cuántos kWh y euros consume tu lavadora,
          nevera u otros aparatos. Los cálculos se basan en el <strong
            >precio actual de la electricidad</strong
          >, actualizado en tiempo real según los datos oficiales de la <strong
            >red eléctrica de España</strong
          >.
        </p>
        <p class="mt-space-s">
          Ideal para hogares y pequeños negocios que buscan ahorrar, planificar
          cargas en las horas más económicas y entender mejor su gasto
          energético.
        </p>
        <!-- CTAs -->
        <div class="hero-ctas mt-space-l">
          <a href="/escanear-factura" class="btn" data-type="accent">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            Escanear factura
          </a>
          <a href="#newsletter" class="btn">
            Suscribirme
          </a>
        </div>
      </div>
      <img
        src={heroImg.src}
        width={heroImg.width / 2}
        height="426"
        loading="eager"
        fetchpriority="high"
        alt="Calculadora de consumo eléctrico"
        class="mt-space-m mb-space-l rounded-md"
      />
    </div>

    <div
      class="bg-primary-900 p-space-l mt-space-xl rounded-md text-neutral-50 bg-texture"
    >
      <Calculator client:load initialPower={1500}
  initialApplianceName="Radiador eléctrico" />

      <!-- ── Promo: Escáner de facturas con IA ────────────── -->
      <a href="/escanear-factura" class="scanner-promo" aria-label="Analiza tu factura de luz o gas con IA — 1 escaneo gratis">
        <div class="scanner-promo__inner">
          <div class="scanner-promo__left">
            <span class="scanner-promo__badge">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
              Nuevo · IA
            </span>
            <h2 class="scanner-promo__title">
              Analiza tu factura de luz o gas con IA
            </h2>
            <p class="scanner-promo__desc">
              Sube una foto o PDF y nuestra inteligencia artificial extrae al instante el consumo en kWh,
              CUPS, términos P1/P2/P3, importes desglosados y consejos personalizados para <strong>reducir tu factura eléctrica</strong>.
            </p>
            <ul class="scanner-promo__features" aria-label="Características del escáner de facturas">
              <li>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Consumo por periodos tarifarios P1/P2/P3
              </li>
              <li>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                CUPS, titular, comercializadora y distribuidora
              </li>
              <li>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Desglose de potencia, energía, IVA e impuesto eléctrico
              </li>
              <li>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Compatible con imágenes JPG/PNG y PDFs · Luz y gas
              </li>
            </ul>
            <div class="scanner-promo__cta-row">
              <span class="btn" data-type="accent" data-size="small">
                Escanear mi factura gratis
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
              <span class="scanner-promo__note">1 análisis gratis · Sin tarjeta de crédito</span>
            </div>
          </div>
          <div class="scanner-promo__visual" aria-hidden="true">
            <div class="scanner-promo__icon-wrap">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </div>
            <div class="scanner-promo__stats">
              <div class="scanner-promo__stat">
                <span class="scanner-stat__val">696</span>
                <span class="scanner-stat__label">kWh</span>
              </div>
              <div class="scanner-promo__stat">
                <span class="scanner-stat__val">172€</span>
                <span class="scanner-stat__label">total</span>
              </div>
              <div class="scanner-promo__stat">
                <span class="scanner-stat__val">P1/P2</span>
                <span class="scanner-stat__label">tarifas</span>
              </div>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="mt-space-2xl">
      <h2 class="text-neutral-50 mb-space-m text-center">
        O selecciona tu electrodoméstico
      </h2>
      <p class="text-neutral-300 mb-space-l max-w-prose mx-auto">
        ¿Buscas un cálculo más preciso? Elige directamente el aparato para ver consejos de ahorro específicos y datos pre-configurados.
      </p>
      <ApplianceGrid />
    </div>
    <hr class="text-neutral-400 my-space-2xl" />
    <h2 id="como-funciona-calculadora" class="text-neutral-50 mt-space-xl">
      Cómo calcula nuestra calculadora de consumo eléctrico en kWh y €
    </h2>
    <p class="mt-space-s">
      ¿Quieres saber <strong
        >cuánto te cuesta usar tu electrodoméstico ahora mismo</strong
      >? Nuestra
      <strong>calculadora de consumo eléctrico en kWh y euros</strong> extrae el
      <strong>precio de la luz por hora</strong> directamente de Red Eléctrica de
      España para ofrecerte un resultado
      <em>en tiempo real</em>.
    </p>
    <p>El cálculo se realiza en dos pasos:</p>
    <ol class="flow mt-space-m">
      <li>
        <strong class="text-neutral-50">Calculamos los kWh:</strong><br />
        <p class="mt-space-xs">
          Multiplicamos la potencia del aparato (vatios, W) por las horas de uso
          y dividimos entre 1 000:<br />
          <code>kWh = (Potencia [W] x Horas de uso) ÷ 1 000</code>
        </p>
      </li>
      <li>
        <strong class="text-neutral-50"
          >Aplicamos el precio actual por hora:</strong
        ><br />
        <p class="mt-space-xs">
          Multiplicamos esos kWh por el precio de la luz vigente en ese tramo
          (€/kWh) y sumamos el 21 % de IVA:<br />
          <code>Coste € = kWh x Precio actual por hora x 1,21</code>
        </p>
      </li>
    </ol>
    <p>
      De este modo obtienes <strong>de inmediato</strong> el gasto diario de tu aparato
      en euros, ideal para programar su uso en las franjas más económicas.
    </p>
   <Table columns={columns} data={data} />
    <h2 class="text-neutral-50 mt-space-xl">
      Diferencia entre vatios (W) y kilovatios hora (kWh)
    </h2>
    <p class="mt-space-s">
      Entender la diferencia entre <strong>vatios (W)</strong> y <strong
        >kilovatios hora (kWh)</strong
      > es fundamental para gestionar el consumo energético de tu hogar o negocio.
      Mientras los <strong>vatios (W)</strong> miden la <strong
        >potencia instantánea</strong
      > de un dispositivo (la energía que consume en un momento dado), los <strong
        >kilovatios hora (kWh)</strong
      > reflejan el <strong>consumo acumulado</strong> durante un período. Por ejemplo,
      una bombilla de 100 W usa 0,1 kWh cada hora. Dominar estos conceptos te permitirá
      leer correctamente tu factura de la luz y optimizar tu consumo energético.
    </p>
    <h2 class="mt-space-xl text-neutral-50">5 consejos para ahorrar energía</h2>
    <p class="mt-space-s">
      Reducir el consumo eléctrico es clave para cuidar el medio ambiente y tu
      bolsillo. Combina <strong>hábitos inteligentes</strong> con tecnología eficiente:
      programa electrodomésticos como lavadoras en <strong>horas valle</strong> (cuando
      la energía es más económica) y apuesta por bombillas <strong>LED</strong> de
      bajo consumo. <a href="/precio-luz-hoy">Consulta aquí</a> las horas más baratas
      del día antes de usar tus electrodomésticos. Pequeños cambios generan grandes
      ahorros.
    </p>

    <ul role="list" class="flow mt-space-xl">
      <li>🔋 Programa lavadoras/lavavajillas en horario valle</li>
      <li>
        💡 Sustituye bombillas tradicionales por LED (hasta 80% de ahorro)
      </li>
      <li>🔌 Desenchufa dispositivos en stand-by (TV, cargadores)</li>
      <li>🌡️ Regula termostatos: 21°C en invierno y 26°C en verano</li>
      <li>🔄 Mantén limpios filtros de aire acondicionado y calderas</li>
    </ul>
  </div>
  <div class="mt-space-xl">
    <Faq data={faqData} />
  </div>
  <div
    id="newsletter"
    class="mt-space-xl text-neutral-50 bg-primary-900 p-space-l rounded-md bg-texture"
  >
    <div class="newsletter-header text-primary-50">
      <h2>⚡¡No te pierdas las horas más baratas de luz!</h2>
      <p class="subtitle mt-space-xs">Recibe cada día un correo con:</p>
      <ListNewsletter />
      <div class="mt-space-m">
        <SubscribeForm client:only="vue" />
      </div>
    </div>
  </div>
</Layout>

<style>
  hr { opacity: 0.2; }
  code { white-space: pre-wrap; }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    align-items: center;
  }
  .newsletter-header { max-width: 48rem; border-radius: 8px; }
  .hero-wrapper {
    display: block;
    grid-template-columns: 1fr 1fr;
    justify-items: center;
    align-items: center;
    & img { display: none; }
  }
  @media (min-width: 63.99875em) {
    .hero-wrapper {
      display: grid;
      & img { display: block; height: auto; }
    }
  }

  /* ── Scanner Promo Card ───────────────────────────── */
  .scanner-promo {
    display: block;
    margin-top: var(--space-l);
    border-radius: 14px;
    border: 1px solid var(--esmerald-green);
    background: linear-gradient(135deg,
      rgba(16,185,129,.08) 0%,
      rgba(16,185,129,.03) 50%,
      transparent 100%);
    text-decoration: none;
    color: inherit;
    transition: border-color .2s, box-shadow .2s;
    box-shadow: 0 0 24px rgba(16,185,129,.08);
  }
  .scanner-promo:hover {
    border-color: color-mix(in srgb, var(--esmerald-green) 80%, white);
    box-shadow: 0 0 36px rgba(16,185,129,.18);
  }
  .scanner-promo:focus-visible {
    outline: 2px solid var(--esmerald-green);
    outline-offset: 3px;
  }
  .scanner-promo__inner {
    display: flex;
    gap: var(--space-l);
    padding: var(--space-l);
    align-items: center;
  }
  .scanner-promo__left { flex: 1; min-width: 0; }

  /* Badge */
  .scanner-promo__badge {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    padding: .25rem .75rem;
    background: rgba(16,185,129,.15);
    border: 1px solid rgba(16,185,129,.35);
    border-radius: 20px;
    font-size: .75rem;
    font-weight: 700;
    color: var(--esmerald-green);
    letter-spacing: .04em;
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }

  /* Heading */
  .scanner-promo__title {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 700;
    color: var(--neutral-50);
    margin: 0 0 var(--space-xs);
    line-height: 1.3;
  }
  .scanner-promo__desc {
    font-size: .9rem;
    color: var(--primary-200);
    line-height: 1.6;
    margin: 0 0 var(--space-s);
    max-width: 52ch;
  }
  .scanner-promo__desc strong { color: var(--neutral-100); }

  /* Feature list */
  .scanner-promo__features {
    list-style: none;
    padding: 0; margin: 0 0 var(--space-m);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .35rem .75rem;
  }
  .scanner-promo__features li {
    display: flex;
    align-items: flex-start;
    gap: .4rem;
    font-size: .82rem;
    color: var(--primary-100);
    line-height: 1.4;
  }
  .scanner-promo__features li svg {
    flex-shrink: 0;
    color: var(--esmerald-green);
    margin-top: .12rem;
  }

  /* CTA */
  .scanner-promo__cta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: .75rem;
  }
  .scanner-promo:hover .btn[data-type="accent"] {
    transform: translateX(2px);
  }
  .scanner-promo__note {
    font-size: .78rem;
    color: var(--primary-400);
  }

  /* Visual side */
  .scanner-promo__visual {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-s);
  }
  .scanner-promo__icon-wrap {
    width: 80px; height: 80px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(16,185,129,.12);
    border: 1px solid rgba(16,185,129,.25);
    border-radius: 20px;
    color: var(--esmerald-green);
  }
  .scanner-promo__stats {
    display: flex;
    gap: .5rem;
  }
  .scanner-promo__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--primary-700);
    border-radius: 8px;
    padding: .4rem .65rem;
    min-width: 52px;
  }
  .scanner-stat__val {
    font-size: .85rem;
    font-weight: 700;
    color: var(--neutral-50);
    white-space: nowrap;
  }
  .scanner-stat__label {
    font-size: .65rem;
    color: var(--primary-400);
    text-transform: uppercase;
    letter-spacing: .05em;
  }

  /* Responsive */
  @media (max-width: 63.99875em) {
    .scanner-promo__visual { display: none; }
    .scanner-promo__features { grid-template-columns: 1fr; }
    .scanner-promo__inner { padding: var(--space-m); }
  }
</style>
